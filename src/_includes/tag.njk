---
layout: base.njk
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: "/posts/tags/{{ tag }}/"
eleventyComputed:
  title: "Posts tagged {{ tag }}"
siteName: "The Sweet Blog"
---

<h3>
  Tagged: #{{ tag }}
</h3>
<br>
<br>
{% for post in collections.posts | filterByTag(tag) %}
  <article>
    <h4><a href="{{ post.url }}">{{ post.data.title }}</a></h4>
    <p>{{ post.data.description }}</p>
    <p><small>{{ post.date | readableDate }}</small></p>
  </article>
{% endfor %}
